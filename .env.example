# Copy to .env and fill in your LLM endpoint / key:  cp .env.example .env

# Directory to scan for videos
VIDEO_DIR=/data/videos

# UID/GID the container runs as (so generated subtitles aren't owned by root)
PUID=1000
PGID=1000

# ---- transcription (faster-whisper) ----
WHISPER_MODEL=large-v3-turbo   # large-v3-turbo | medium | small | ...
SOURCE_LANG=ja                 # language of the audio
WHISPER_DEVICE=cpu             # cpu | cuda
WHISPER_COMPUTE_TYPE=int8      # int8 (cpu) | float16 (gpu) | ...
WHISPER_THREADS=4              # CPU threads (0 = all cores)

# ---- translation (any OpenAI-compatible Chat Completions endpoint) ----
LITELLM_URL=http://your-llm-gateway:4000/v1/chat/completions
LLM_MODEL=your-model-name
TRANSLATE_KEY=                 # API key / token for the endpoint
BATCH_SIZE=30                  # subtitle lines per request

# ---- scheduling & resource limits ----
SCAN_HOUR=4                    # hour of day (0-23) to re-scan
CPU_SHARES=256                 # relative Docker CPU weight (default 1024)

# External Docker network to join so the container can reach a gateway on the
# same host by service name. Delete the networks: blocks in docker-compose.yml
# if your endpoint is a public URL instead.
LLM_NETWORK=litellm_default
